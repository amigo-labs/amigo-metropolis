{
  "name": "amigo-metropolis",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "test": "bun test",
    "lint": "biome check .",
    "typecheck": "bun run --filter '*' typecheck",
    "build": "bun run --filter '*' build",
    "dev": "bun run --filter @metropolis/client dev",
    "gen:units": "bun run tools/generators/genUnitModels.ts",
    "replay:verify": "bun run tools/determinism/src/cli.ts verify-goldens",
    "replay:verify:browser": "bun run tools/determinism/src/browserVerify.ts",
    "e2e:touch": "bun run tools/determinism/src/touchInput.ts",
    "verify:arenas": "bun run tools/determinism/src/arenaShots.ts",
    "verify:units": "bun run tools/determinism/src/unitShots.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
