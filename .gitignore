# them local — copy from the RE-repo extracted/meshes/<Cont>/atlas/ when needed.
packages/client/public/models/*/atlas-*.png
!packages/client/public/models/la-cantina/atlas-*.png

# wrangler dev local state (packages/server bun run dev)
